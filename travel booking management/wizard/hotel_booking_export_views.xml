<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hotel_booking_export_form" model="ir.ui.view">
        <field name="name">travel.hotel.booking.export.form</field>
        <field name="model">travel.hotel.booking.export</field>
        <field name="arch" type="xml">
            <form string="Export Hotel Bookings">
                <group>
                    <group>
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                    <group>
                        <field name="state_filter"/>
                    </group>
                </group>
                <group invisible="not excel_file">
                    <field name="excel_file" filename="file_name"/>
                    <field name="file_name" invisible="1"/>
                </group>
                <footer>
                    <button name="action_export" string="Export to Excel" type="object" class="oe_highlight"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_hotel_booking_export" model="ir.actions.act_window">
        <field name="name">Export Hotel Bookings</field>
        <field name="res_model">travel.hotel.booking.export</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
