<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_train_booking_form" model="ir.ui.view">
        <field name="name">travel.train.booking.form</field>
        <field name="model">travel.train.booking</field>
        <field name="arch" type="xml">
            <form string="Train Booking">
                <header>
                    <button name="action_confirm" string="Confirm" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_done" string="Done" type="object" class="oe_highlight" invisible="state != 'confirmed'"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state in ('done', 'cancelled')"/>
                    <button name="action_draft" string="Reset to Draft" type="object" invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,done"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="name" readonly="1"/></h1></div>
                    <group>
                        <group string="Booking Info">
                            <field name="booking_date"/>
                            <field name="booking_executive"/>
                            <field name="passenger_names"/>
                            <field name="num_passengers"/>
                            <field name="employee_code" placeholder="Do not put NA"/>
                            <field name="billing_company_id"/>
                            <field name="document_number"/>
                        </group>
                        <group string="Train Info">
                            <field name="origin_station"/>
                            <field name="destination_station"/>
                            <field name="travel_class"/>
                            <field name="quota"/>
                            <field name="pnr_number"/>
                            <field name="travel_date"/>
                            <field name="train_number"/>
                        </group>
                    </group>
                    <group>
                        <group string="Payment">
                            <field name="total_amount"/>
                            <field name="gst_amount"/>
                            <field name="mode_of_payment"/>
                            <field name="booking_account" placeholder="Do not put NA"/>
                        </group>
                        <group string="Confirmation">
                            <field name="remarks"/>
                            <field name="confirmed_by"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Cancellation" invisible="not cancellation_id">
                            <field name="cancellation_id"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_train_booking_list" model="ir.ui.view">
        <field name="name">travel.train.booking.list</field>
        <field name="model">travel.train.booking</field>
        <field name="arch" type="xml">
            <list string="Train Bookings"
                  decoration-info="state == 'draft'"
                  decoration-warning="state == 'confirmed'"
                  decoration-success="state == 'done'"
                  decoration-danger="state == 'cancelled'">
                <field name="name"/>
                <field name="booking_date"/>
                <field name="booking_executive"/>
                <field name="passenger_names"/>
                <field name="num_passengers"/>
                <field name="employee_code"/>
                <field name="billing_company_id"/>
                <field name="document_number"/>
                <field name="origin_station"/>
                <field name="destination_station"/>
                <field name="travel_class"/>
                <field name="quota"/>
                <field name="pnr_number"/>
                <field name="travel_date"/>
                <field name="train_number"/>
                <field name="total_amount"/>
                <field name="gst_amount"/>
                <field name="mode_of_payment"/>
                <field name="booking_account"/>
                <field name="remarks"/>
                <field name="confirmed_by"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'confirmed'"
                       decoration-success="state == 'done'"
                       decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <record id="action_train_booking" model="ir.actions.act_window">
        <field name="name">Train Bookings</field>
        <field name="res_model">travel.train.booking</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_train_booking_export_selected" model="ir.actions.server">
        <field name="name">Export to Excel</field>
        <field name="model_id" ref="model_travel_train_booking"/>
        <field name="binding_model_id" ref="model_travel_train_booking"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
action = {
    'type': 'ir.actions.act_window',
    'name': 'Export Train Bookings',
    'res_model': 'travel.train.booking.export',
    'view_mode': 'form',
    'target': 'new',
    'context': {'active_ids': env.context.get('active_ids', []), 'active_model': 'travel.train.booking'},
}
        </field>
    </record>
</odoo>
