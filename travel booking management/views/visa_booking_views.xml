<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_visa_booking_form" model="ir.ui.view">
        <field name="name">travel.visa.booking.form</field>
        <field name="model">travel.visa.booking</field>
        <field name="arch" type="xml">
            <form string="Visa Booking">
                <header>
                    <button name="action_submit" string="Submit" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_processing" string="Processing" type="object" class="oe_highlight" invisible="state != 'submitted'"/>
                    <button name="action_approve" string="Approve" type="object" class="oe_highlight" invisible="state != 'processing'"/>
                    <button name="action_reject" string="Reject" type="object" invisible="state != 'processing'"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state in ('approved', 'rejected', 'cancelled')"/>
                    <button name="action_draft" string="Reset to Draft" type="object" invisible="state not in ('rejected', 'cancelled')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,processing,approved"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="name" readonly="1"/></h1></div>
                    <group>
                        <group string="Booking Info">
                            <field name="billing_company_id"/>
                            <field name="booking_date"/>
                            <field name="booking_executive"/>
                            <field name="booking_type"/>
                            <field name="employee_code"/>
                            <field name="document_number"/>
                        </group>
                        <group string="Passenger Info">
                            <field name="passenger_name"/>
                            <field name="reference_number"/>
                            <field name="confirmed_by"/>
                            <field name="mode_of_payment"/>
                        </group>
                    </group>
                    <group>
                        <group string="Description">
                            <field name="description" nolabel="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Cancellation" invisible="not cancellation_id">
                            <field name="cancellation_id"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_visa_booking_list" model="ir.ui.view">
        <field name="name">travel.visa.booking.list</field>
        <field name="model">travel.visa.booking</field>
        <field name="arch" type="xml">
            <list string="Visa Bookings"
                  decoration-info="state == 'draft'"
                  decoration-warning="state == 'processing'"
                  decoration-success="state == 'approved'"
                  decoration-danger="state in ('rejected', 'cancelled')">
                <field name="name"/>
                <field name="billing_company_id"/>
                <field name="passenger_name"/>
                <field name="booking_type"/>
                <field name="booking_date"/>
                <field name="booking_executive"/>
                <field name="employee_code"/>
                <field name="document_number"/>
                <field name="reference_number"/>
                <field name="confirmed_by"/>
                <field name="mode_of_payment"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'processing'"
                       decoration-success="state == 'approved'"
                       decoration-danger="state in ('rejected', 'cancelled')"/>
            </list>
        </field>
    </record>

    <record id="view_visa_booking_search" model="ir.ui.view">
        <field name="name">travel.visa.booking.search</field>
        <field name="model">travel.visa.booking</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="billing_company_id"/>
                <field name="passenger_name"/>
                <field name="reference_number"/>
                <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                <filter string="Processing" name="processing" domain="[('state','=','processing')]"/>
                <filter string="Approved" name="approved" domain="[('state','=','approved')]"/>
                <group expand="0" string="Group By">
                    <filter string="Billing Company" name="group_company" context="{'group_by': 'billing_company_id'}"/>
                    <filter string="Booking Type" name="group_type" context="{'group_by': 'booking_type'}"/>
                    <filter string="Booking Executive" name="group_executive" context="{'group_by': 'booking_executive'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_visa_booking" model="ir.actions.act_window">
        <field name="name">Visa Bookings</field>
        <field name="res_model">travel.visa.booking</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
