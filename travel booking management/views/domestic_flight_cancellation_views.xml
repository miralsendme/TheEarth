<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_domestic_flight_cancellation_form" model="ir.ui.view">
        <field name="name">travel.domestic.flight.cancellation.form</field>
        <field name="model">travel.domestic.flight.cancellation</field>
        <field name="arch" type="xml">
            <form string="Domestic Flight Cancellation">
                <header>
                    <button name="action_confirm" string="Confirm Cancellation" type="object"
                            class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_refund" string="Mark Refunded" type="object"
                            class="oe_highlight" invisible="state != 'confirmed'"/>
                    <button name="action_reject" string="Reject" type="object"
                            invisible="state != 'draft'"/>
                    <button name="action_draft" string="Reset to Draft" type="object"
                            invisible="state not in ('rejected',)"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,refunded"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="name" readonly="1"/></h1></div>
                    <group>
                        <group>
                            <field name="cancellation_date"/>
                            <field name="booking_executive"/>
                            <field name="passenger_names"/>
                            <field name="num_cancelled_passengers"/>
                            <field name="employee_code"/>
                            <field name="billing_company_id"/>
                            <field name="document_number"/>
                            <field name="origin_city"/>
                            <field name="destination_city"/>
                            <field name="return_origin" invisible="trip_type not in ('round_trip',)"/>
                            <field name="return_destination" invisible="trip_type not in ('round_trip',)"/>
                            <field name="trip_type"/>
                        </group>
                        <group>
                            <field name="travel_date_onward"/>
                            <field name="return_date" invisible="trip_type not in ('round_trip',)"/>
                            <field name="ticket_number"/>
                            <field name="pnr_number"/>
                            <field name="split_pnr"/>
                            <field name="flight_number"/>
                            <field name="flight_number_return"/>
                            <field name="travel_class"/>
                            <field name="airline"/>
                            <field name="fare"/>
                            <field name="refund_amount"/>
                            <field name="mode_of_refund"/>
                            <field name="fare_type"/>
                            <field name="remarks"/>
                            <field name="confirmed_by"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_domestic_flight_cancellation_list" model="ir.ui.view">
        <field name="name">travel.domestic.flight.cancellation.list</field>
        <field name="model">travel.domestic.flight.cancellation</field>
        <field name="arch" type="xml">
            <list string="Domestic Flight Cancellations" decoration-danger="state == 'rejected'"
                  decoration-success="state == 'refunded'" decoration-info="state == 'confirmed'">
                <field name="name"/>
                <field name="cancellation_date"/>
                <field name="booking_executive"/>
                <field name="passenger_names"/>
                <field name="billing_company_id"/>
                <field name="origin_city"/>
                <field name="destination_city"/>
                <field name="airline"/>
                <field name="fare"/>
                <field name="refund_amount"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'confirmed'"
                       decoration-success="state == 'refunded'"
                       decoration-danger="state == 'rejected'"/>
            </list>
        </field>
    </record>

    <record id="view_domestic_flight_cancellation_search" model="ir.ui.view">
        <field name="name">travel.domestic.flight.cancellation.search</field>
        <field name="model">travel.domestic.flight.cancellation</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="passenger_names"/>
                <field name="billing_company_id"/>
                <field name="pnr_number"/>
                <field name="airline"/>
                <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                <filter string="Confirmed" name="confirmed" domain="[('state','=','confirmed')]"/>
                <filter string="Refunded" name="refunded" domain="[('state','=','refunded')]"/>
                <group expand="0" string="Group By">
                    <filter string="Billing Company" name="group_company" context="{'group_by': 'billing_company_id'}"/>
                    <filter string="Airline" name="group_airline" context="{'group_by': 'airline'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_domestic_flight_cancellation" model="ir.actions.act_window">
        <field name="name">Domestic Flight Cancellations</field>
        <field name="res_model">travel.domestic.flight.cancellation</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
