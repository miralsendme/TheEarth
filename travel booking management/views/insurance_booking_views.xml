<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_insurance_booking_form" model="ir.ui.view">
        <field name="name">travel.insurance.booking.form</field>
        <field name="model">travel.insurance.booking</field>
        <field name="arch" type="xml">
            <form string="Insurance Booking">
                <header>
                    <button name="action_confirm" string="Confirm" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_done" string="Done" type="object" class="oe_highlight" invisible="state != 'confirmed'"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state in ('done', 'cancelled')"/>
                    <button name="action_draft" string="Reset to Draft" type="object" invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,done"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="name" readonly="1"/></h1></div>
                    <group>
                        <group string="Customer">
                            <field name="partner_id"/>
                            <field name="num_travellers"/>
                        </group>
                        <group string="Insurance Info">
                            <field name="insurance_provider"/>
                            <field name="policy_number"/>
                            <field name="insurance_type"/>
                            <field name="coverage_amount"/>
                        </group>
                    </group>
                    <group>
                        <group string="Coverage Period">
                            <field name="destination_country_id"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </group>
                        <group string="Nominee">
                            <field name="nominee_name"/>
                            <field name="nominee_relation"/>
                        </group>
                    </group>
                    <group>
                        <group string="Payment">
                            <field name="premium_amount"/>
                            <field name="currency_id" groups="base.group_multi_currency"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes"><field name="notes"/></page>
                        <page string="Cancellation" invisible="not cancellation_id">
                            <field name="cancellation_id"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="view_insurance_booking_list" model="ir.ui.view">
        <field name="name">travel.insurance.booking.list</field>
        <field name="model">travel.insurance.booking</field>
        <field name="arch" type="xml">
            <list string="Insurance Bookings">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="insurance_provider"/>
                <field name="insurance_type"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="premium_amount"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>
    <record id="view_insurance_booking_search" model="ir.ui.view">
        <field name="name">travel.insurance.booking.search</field>
        <field name="model">travel.insurance.booking</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="insurance_provider"/>
                <field name="policy_number"/>
                <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                <filter string="Confirmed" name="confirmed" domain="[('state','=','confirmed')]"/>
                <group expand="0" string="Group By">
                    <filter string="Customer" name="group_customer" context="{'group_by': 'partner_id'}"/>
                    <filter string="Type" name="group_type" context="{'group_by': 'insurance_type'}"/>
                </group>
            </search>
        </field>
    </record>
    <record id="action_insurance_booking" model="ir.actions.act_window">
        <field name="name">Insurance Bookings</field>
        <field name="res_model">travel.insurance.booking</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
