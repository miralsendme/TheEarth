<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_domestic_flight_booking_form" model="ir.ui.view">
        <field name="name">travel.domestic.flight.booking.form</field>
        <field name="model">travel.domestic.flight.booking</field>
        <field name="arch" type="xml">
            <form string="Domestic Flight Booking">
                <header>
                    <button name="action_confirm" string="Confirm" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_done" string="Done" type="object" class="oe_highlight" invisible="state != 'confirmed'"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state in ('done', 'cancelled')"/>
                    <button name="action_draft" string="Reset to Draft" type="object" invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,done"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="name" readonly="1"/></h1></div>
                    <group>
                        <group string="Booking">
                            <field name="billing_company_id"/>
                            <field name="booking_date"/>
                            <field name="booking_executive"/>
                            <field name="employee_code"/>
                            <field name="document_number"/>
                        </group>
                        <group string="Flight Info">
                            <field name="airline"/>
                            <field name="flight_number"/>
                            <field name="flight_number_return" invisible="trip_type != 'round_trip'"/>
                            <field name="pnr_number"/>
                            <field name="ticket_number"/>
                            <field name="travel_class"/>
                            <field name="baggage_allowance"/>
                        </group>
                    </group>
                    <group>
                        <group string="Route">
                            <field name="origin_city"/>
                            <field name="destination_city"/>
                            <field name="trip_type"/>
                        </group>
                        <group string="Schedule (Onwards)">
                            <field name="departure_date"/>
                            <field name="arrival_date"/>
                        </group>
                    </group>
                    <group invisible="trip_type != 'round_trip'">
                        <group string="Return Journey">
                            <field name="return_travel_date"/>
                            <field name="return_origin"/>
                            <field name="return_destination"/>
                        </group>
                        <group string="Schedule (Return)">
                            <field name="return_departure_date"/>
                            <field name="return_arrival_date"/>
                        </group>
                    </group>
                    <group>
                        <group string="Passenger Details">
                            <field name="passenger_names" placeholder="Enter one passenger name per line..."/>
                            <field name="num_passengers"/>
                        </group>
                        <group string="Payment">
                            <field name="gross_amount"/>
                            <field name="gst_amount"/>
                            <field name="total_amount"/>
                            <field name="currency_id" groups="base.group_multi_currency"/>
                            <field name="mode_of_payment"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes"><field name="notes"/></page>
                        <page string="Cancellation" invisible="not cancellation_id">
                            <field name="cancellation_id"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="view_domestic_flight_booking_list" model="ir.ui.view">
        <field name="name">travel.domestic.flight.booking.list</field>
        <field name="model">travel.domestic.flight.booking</field>
        <field name="arch" type="xml">
            <list string="Domestic Flight Bookings">
                <field name="name"/>
                <field name="billing_company_id"/>
                <field name="booking_executive"/>
                <field name="airline"/>
                <field name="flight_number"/>
                <field name="origin_city"/>
                <field name="destination_city"/>
                <field name="booking_date"/>
                <field name="departure_date"/>
                <field name="trip_type"/>
                <field name="travel_class"/>
                <field name="num_passengers"/>
                <field name="pnr_number"/>
                <field name="ticket_number"/>
                <field name="total_amount"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>
    <record id="view_domestic_flight_booking_search" model="ir.ui.view">
        <field name="name">travel.domestic.flight.booking.search</field>
        <field name="model">travel.domestic.flight.booking</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="billing_company_id"/>
                <field name="airline"/>
                <field name="pnr_number"/>
                <field name="ticket_number"/>
                <field name="booking_executive"/>
                <field name="employee_code"/>
                <filter string="Today's Departures" name="today_departures" domain="[('departure_date', '&gt;=', context_today().strftime('%%Y-%%m-%%d 00:00:00')), ('departure_date', '&lt;=', context_today().strftime('%%Y-%%m-%%d 23:59:59'))]"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                <filter string="Confirmed" name="confirmed" domain="[('state','=','confirmed')]"/>
                <group expand="0" string="Group By">
                    <filter string="Billing Company" name="group_company" context="{'group_by': 'billing_company_id'}"/>
                    <filter string="Booking Executive" name="group_executive" context="{'group_by': 'booking_executive'}"/>
                    <filter string="Booking Date" name="group_booking_date" context="{'group_by': 'booking_date:day'}"/>
                    <filter string="Airline" name="group_airline" context="{'group_by': 'airline'}"/>
                    <filter string="Trip Type" name="group_trip" context="{'group_by': 'trip_type'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>
    <record id="action_domestic_flight_booking" model="ir.actions.act_window">
        <field name="name">Domestic Flight Bookings</field>
        <field name="res_model">travel.domestic.flight.booking</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
