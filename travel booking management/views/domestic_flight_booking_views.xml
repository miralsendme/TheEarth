<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_domestic_flight_booking_form" model="ir.ui.view">
        <field name="name">travel.domestic.flight.booking.form</field>
        <field name="model">travel.domestic.flight.booking</field>
        <field name="arch" type="xml">
            <form string="Domestic Flight Booking">
                <header>
                    <button name="action_confirm" string="Confirm" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_done" string="Done" type="object" class="oe_highlight" invisible="state != 'confirmed'"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state in ('done', 'cancelled')"/>
                    <button name="action_draft" string="Reset to Draft" type="object" invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,done"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="name" readonly="1"/></h1></div>
                    <group>
                        <group string="Booking Info">
                            <field name="booking_date"/>
                            <field name="booking_executive"/>
                            <field name="passenger_names"/>
                            <field name="num_passengers"/>
                            <field name="employee_code" placeholder="Do not put NA"/>
                            <field name="billing_company_id"/>
                            <field name="document_number"/>
                        </group>
                        <group string="Flight Info">
                            <field name="origin_city"/>
                            <field name="destination_city"/>
                            <field name="return_origin"/>
                            <field name="return_destination"/>
                            <field name="trip_type"/>
                            <field name="travel_date_onward"/>
                            <field name="return_date"/>
                        </group>
                    </group>
                    <group>
                        <group string="Ticket Details">
                            <field name="ticket_number"/>
                            <field name="pnr_number" placeholder="CRS PNR / BOOKING REF NO IF LCC AIRLINE"/>
                            <field name="flight_number"/>
                            <field name="flight_number_return"/>
                            <field name="travel_class"/>
                            <field name="airline"/>
                        </group>
                        <group string="Payment &amp; Confirmation">
                            <field name="gross_amount"/>
                            <field name="total_amount"/>
                            <field name="gst_amount" placeholder="Only if GST claim is allowed"/>
                            <field name="mode_of_payment"/>
                            <field name="remarks"/>
                            <field name="confirmed_by"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Cancellation" invisible="not cancellation_id">
                            <field name="cancellation_id"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_domestic_flight_booking_list" model="ir.ui.view">
        <field name="name">travel.domestic.flight.booking.list</field>
        <field name="model">travel.domestic.flight.booking</field>
        <field name="arch" type="xml">
            <list string="Domestic Flight Bookings"
                  decoration-info="state == 'draft'"
                  decoration-warning="state == 'confirmed'"
                  decoration-success="state == 'done'"
                  decoration-danger="state == 'cancelled'">
                <field name="name"/>
                <field name="booking_date"/>
                <field name="booking_executive"/>
                <field name="passenger_names"/>
                <field name="num_passengers"/>
                <field name="employee_code"/>
                <field name="billing_company_id"/>
                <field name="document_number"/>
                <field name="origin_city"/>
                <field name="destination_city"/>
                <field name="return_origin"/>
                <field name="return_destination"/>
                <field name="trip_type"/>
                <field name="travel_date_onward"/>
                <field name="return_date"/>
                <field name="ticket_number"/>
                <field name="pnr_number"/>
                <field name="flight_number"/>
                <field name="flight_number_return"/>
                <field name="travel_class"/>
                <field name="airline"/>
                <field name="gross_amount"/>
                <field name="total_amount"/>
                <field name="gst_amount"/>
                <field name="mode_of_payment"/>
                <field name="remarks"/>
                <field name="confirmed_by"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'confirmed'"
                       decoration-success="state == 'done'"
                       decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <record id="action_domestic_flight_booking" model="ir.actions.act_window">
        <field name="name">Domestic Flight Bookings</field>
        <field name="res_model">travel.domestic.flight.booking</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
