<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_package_tour_booking_form" model="ir.ui.view">
        <field name="name">travel.package.tour.booking.form</field>
        <field name="model">travel.package.tour.booking</field>
        <field name="arch" type="xml">
            <form string="Package Tour Booking">
                <header>
                    <button name="action_confirm" string="Confirm" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_done" string="Done" type="object" class="oe_highlight" invisible="state != 'confirmed'"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state in ('done', 'cancelled')"/>
                    <button name="action_draft" string="Reset to Draft" type="object" invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,done"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="name" readonly="1"/></h1></div>
                    <group>
                        <group string="Booking Info">
                            <field name="billing_company_id"/>
                            <field name="booking_date"/>
                            <field name="booking_executive"/>
                            <field name="booking_type"/>
                            <field name="location_type"/>
                            <field name="employee_code"/>
                            <field name="document_number"/>
                        </group>
                        <group string="Passenger Info">
                            <field name="passenger_names" placeholder="Enter one passenger name per line..."/>
                            <field name="num_passengers"/>
                            <field name="reference_number"/>
                            <field name="confirmed_by" required="1"/>
                            <field name="mode_of_payment"/>
                            <field name="amount"/>
                            <field name="currency_id" groups="base.group_multi_currency"/>
                        </group>
                    </group>
                    <group>
                        <group string="Description">
                            <field name="description" nolabel="1"/>
                        </group>
                        <group string="Remarks">
                            <field name="remarks" nolabel="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Cancellation" invisible="not cancellation_id">
                            <field name="cancellation_id"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_package_tour_booking_list" model="ir.ui.view">
        <field name="name">travel.package.tour.booking.list</field>
        <field name="model">travel.package.tour.booking</field>
        <field name="arch" type="xml">
            <list string="Package Tour Bookings"
                  decoration-info="state == 'draft'"
                  decoration-warning="state == 'confirmed'"
                  decoration-success="state == 'done'"
                  decoration-danger="state == 'cancelled'">
                <field name="name"/>
                <field name="billing_company_id"/>
                <field name="booking_type"/>
                <field name="location_type"/>
                <field name="booking_date"/>
                <field name="booking_executive"/>
                <field name="employee_code"/>
                <field name="num_passengers"/>
                <field name="reference_number"/>
                <field name="amount"/>
                <field name="mode_of_payment"/>
                <field name="confirmed_by"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'confirmed'"
                       decoration-success="state == 'done'"
                       decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <record id="view_package_tour_booking_search" model="ir.ui.view">
        <field name="name">travel.package.tour.booking.search</field>
        <field name="model">travel.package.tour.booking</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="billing_company_id"/>
                <field name="reference_number"/>
                <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                <filter string="Confirmed" name="confirmed" domain="[('state','=','confirmed')]"/>
                <filter string="Done" name="done" domain="[('state','=','done')]"/>
                <separator/>
                <filter string="Package Tour" name="package_tour" domain="[('booking_type','=','package_tour')]"/>
                <filter string="Cruise" name="cruise" domain="[('booking_type','=','cruise')]"/>
                <separator/>
                <filter string="Domestic" name="domestic" domain="[('location_type','=','domestic')]"/>
                <filter string="International" name="international" domain="[('location_type','=','international')]"/>
                <group expand="0" string="Group By">
                    <filter string="Billing Company" name="group_company" context="{'group_by': 'billing_company_id'}"/>
                    <filter string="Booking Type" name="group_type" context="{'group_by': 'booking_type'}"/>
                    <filter string="Location Type" name="group_location" context="{'group_by': 'location_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_package_tour_booking" model="ir.actions.act_window">
        <field name="name">Package Tour Bookings</field>
        <field name="res_model">travel.package.tour.booking</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
