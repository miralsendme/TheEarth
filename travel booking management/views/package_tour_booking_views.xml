<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_package_tour_form" model="ir.ui.view">
        <field name="name">travel.package.tour.booking.form</field>
        <field name="model">travel.package.tour.booking</field>
        <field name="arch" type="xml">
            <form string="Package Tour Booking">
                <header>
                    <button name="action_confirm" string="Confirm" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_done" string="Done" type="object" class="oe_highlight" invisible="state != 'confirmed'"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state in ('done', 'cancelled')"/>
                    <button name="action_draft" string="Reset to Draft" type="object" invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,done"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="name" readonly="1"/></h1></div>
                    <group>
                        <group string="Customer">
                            <field name="partner_id"/>
                            <field name="num_adults"/>
                            <field name="num_children"/>
                        </group>
                        <group string="Tour Info">
                            <field name="package_name"/>
                            <field name="tour_type"/>
                            <field name="destination"/>
                            <field name="country_id"/>
                        </group>
                    </group>
                    <group>
                        <group string="Schedule">
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="duration_days"/>
                        </group>
                        <group string="Payment">
                            <field name="total_amount"/>
                            <field name="currency_id" groups="base.group_multi_currency"/>
                        </group>
                    </group>
                    <group string="Inclusions">
                        <field name="includes_hotel"/>
                        <field name="includes_flight"/>
                        <field name="includes_meals"/>
                        <field name="includes_sightseeing"/>
                        <field name="includes_transfer"/>
                        <field name="includes_insurance"/>
                    </group>
                    <notebook>
                        <page string="Itinerary"><field name="itinerary"/></page>
                        <page string="Notes"><field name="notes"/></page>
                        <page string="Cancellation" invisible="not cancellation_id">
                            <field name="cancellation_id"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="view_package_tour_list" model="ir.ui.view">
        <field name="name">travel.package.tour.booking.list</field>
        <field name="model">travel.package.tour.booking</field>
        <field name="arch" type="xml">
            <list string="Package Tour Bookings">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="package_name"/>
                <field name="destination"/>
                <field name="tour_type"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="duration_days"/>
                <field name="total_amount"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>
    <record id="view_package_tour_search" model="ir.ui.view">
        <field name="name">travel.package.tour.booking.search</field>
        <field name="model">travel.package.tour.booking</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="package_name"/>
                <field name="destination"/>
                <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                <filter string="Confirmed" name="confirmed" domain="[('state','=','confirmed')]"/>
                <filter string="Domestic" name="domestic" domain="[('tour_type','=','domestic')]"/>
                <filter string="International" name="international" domain="[('tour_type','=','international')]"/>
                <group expand="0" string="Group By">
                    <filter string="Customer" name="group_customer" context="{'group_by': 'partner_id'}"/>
                    <filter string="Tour Type" name="group_type" context="{'group_by': 'tour_type'}"/>
                </group>
            </search>
        </field>
    </record>
    <record id="action_package_tour_booking" model="ir.actions.act_window">
        <field name="name">Package Tour Bookings</field>
        <field name="res_model">travel.package.tour.booking</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
